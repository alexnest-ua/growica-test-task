# EditorConfig — aligns with WordPress Coding Standards (tabs for code)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# WordPress Coding Standards: real tabs for PHP, CSS, JS
[*.{php,css,js}]
indent_style = tab

# Markdown / YAML / JSON: spaces
[*.{md,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
